# ==============================================================================
# DEVFLOW COMMAND CENTER - GLOBAL ENVIRONMENT VARIABLES
# ==============================================================================

# ------------------------------------------------------------------------------
# App & Security Settings
# ------------------------------------------------------------------------------
# Name of the project, used in headers and OpenAPI metadata.
PROJECT_NAME=DevFlow

# Base prefix string for the backend REST API version 1 routers.
API_V1_STR=/api/v1

# Secret key used to sign JWT access and refresh tokens. Keep this private!
# Generate using: openssl rand -hex 32
SECRET_KEY=9a15f03d5267bb56c28f9d6c4d4be5c2cebb910609ea8b584d4fa7ba9b14b872

# Hashing algorithm used to secure access JWT tokens.
ALGORITHM=HS256

# Validity window of the JWT Access Token in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Validity window of the JWT Refresh Token in days. Set in HttpOnly secure cookie.
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cryptographic key used to encrypt sensitive database values (e.g. access tokens).
# Must be a 32-byte url-safe base64 key.
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ZTMxYzg5NmFiY2RlZjAxMjM0NTY3ODlhYmNkZWYwMTI=

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
# Hostname server where the PostgreSQL database resides.
# Use 'db' when running within Docker, or 'localhost' when running natively.
POSTGRES_SERVER=localhost

# Port number exposing the PostgreSQL database daemon.
POSTGRES_PORT=5432

# Master database administrator username.
POSTGRES_USER=devflow

# Master database administrator password. Keep secure!
POSTGRES_PASSWORD=devflow_password

# Primary database name where records are mapped.
POSTGRES_DB=devflow

# ------------------------------------------------------------------------------
# Redis Settings
# ------------------------------------------------------------------------------
# Hostname server where the Redis daemon resides.
# Use 'redis' when running within Docker, or 'localhost' when running natively.
REDIS_HOST=localhost

# Port number exposing the Redis server.
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Frontend Application Settings
# ------------------------------------------------------------------------------
# Port number Next.js will expose.
PORT=3000

# Next.js hostname. Set to 0.0.0.0 for containerized interface visibility.
HOSTNAME=0.0.0.0

# Public-facing API URL accessed by client browser queries.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ------------------------------------------------------------------------------
# Third-party Integrations (To be setup in Phase 2)
# ------------------------------------------------------------------------------
# GitHub OAuth App Client ID credential.
GITHUB_CLIENT_ID=mock_client_id

# GitHub OAuth App Client Secret credential.
GITHUB_CLIENT_SECRET=mock_client_secret

# Redirect URI where users are returned after performing GitHub OAuth authorization.
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github
