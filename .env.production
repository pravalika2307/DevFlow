# ==============================================================================
# DEVFLOW COMMAND CENTER - PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# App & Security Settings
# ------------------------------------------------------------------------------
PROJECT_NAME=DevFlow
API_V1_STR=/api/v1

# CRITICAL: Generate a strong secure key using: openssl rand -hex 32
SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY_MUST_BE_SECURE

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CRITICAL: Generate a strong URL-safe base64 key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_PRODUCTION_FERNET_32_BYTE_BASE64_KEY

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
# Hostname where production PG cluster is running.
POSTGRES_SERVER=production-db-host-or-rds-endpoint
POSTGRES_PORT=5432

# Master DB User
POSTGRES_USER=devflow_admin

# CRITICAL: Generate a strong password
POSTGRES_PASSWORD=YOUR_PRODUCTION_DB_PASSWORD

POSTGRES_DB=devflow_prod

# ------------------------------------------------------------------------------
# Redis Settings
# ------------------------------------------------------------------------------
# Hostname where production Redis instance is running.
REDIS_HOST=production-redis-host
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Frontend Application Settings
# ------------------------------------------------------------------------------
PORT=3000
HOSTNAME=0.0.0.0

# Set to the production API gateway URL
NEXT_PUBLIC_API_URL=https://api.devflow.io/api/v1

# ------------------------------------------------------------------------------
# Third-party Integrations
# ------------------------------------------------------------------------------
# Obtain these from the production GitHub App setup page.
GITHUB_CLIENT_ID=YOUR_PRODUCTION_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_PRODUCTION_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=https://devflow.io/api/auth/callback/github
